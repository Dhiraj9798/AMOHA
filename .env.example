# Environment Configuration Example
# Copy this to .env and update values as needed

# Database (if you add database later)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=amoha_logistics

# Email Configuration (if you add email functionality)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=your_user
MAIL_PASSWORD=your_password

# Application Settings
APP_ENV=production
APP_DEBUG=false
